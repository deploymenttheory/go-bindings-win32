{{define "interface"}}
{{- if .DocURL}}// {{.TypeName}}: {{.DocURL}}
{{end -}}
{{- if .GUID}}// IID: {{.GUID}}
{{end -}}
{{- if .BaseNote}}// {{.BaseNote}}
{{end -}}
type {{.TypeName}} struct {
{{- if .BaseType}}
	{{.BaseType}}
{{- else}}
	LpVtbl *[1024]uintptr
{{- end}}
}

{{if .IIDVar}}// {{.IIDVar}} is the interface identifier for {{.TypeName}}.
