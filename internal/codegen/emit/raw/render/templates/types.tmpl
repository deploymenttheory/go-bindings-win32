{{define "enum"}}
{{- if .DocURL}}// {{.TypeName}}: {{.DocURL}}
{{end -}}
{{- if .IsFlags}}// Bitmask — values may be combined with |.
{{end -}}
type {{.TypeName}} {{.BaseType}}

{{if .Members}}const (
{{- range .Members}}
	{{.Name}} {{$.TypeName}} = {{.Value}}
{{- end}}
)

// String returns the {{.TypeName}} constant's name, or its numeric form when
// the value is not a known constant.
func (e {{.TypeName}}) String() string {
{{- if .IsFlags}}
	var parts []string
{{- range .Members}}{{if not .IsZero}}
	if e&{{.Name}} != 0 {
		parts = append(parts, "{{.Name}}")
	}
{{- end}}{{end}}
	if len(parts) == 0 {
		return "0"
	}
	return strings.Join(parts, "|")
{{- else}}
	switch e {
{{- range .UniqueMembers}}
	case {{.Name}}:
		return "{{.Name}}"
{{- end}}
	default:
		return fmt.Sprintf("{{.TypeName}}(%d)", {{.BaseType}}(e))
	}
{{- end}}
}

{{end}}{{end}}

{{define "struct"}}
{{- if .DocURL}}// {{.TypeName}}: {{.DocURL}}
{{end -}}
{{- if .IsUnionBlob}}// {{.TypeName}} is a C union, exposed as correctly sized and aligned backing
// storage; read or write a specific member through an unsafe.Pointer cast.
{{end -}}
{{- if .IsPackedBlob}}// {{.TypeName}} is a packed C struct (non-default field alignment), exposed as
// correctly sized and aligned opaque backing storage; read or write a specific
// field through an unsafe.Pointer cast.
{{end -}}
type {{.TypeName}} struct {
{{- range .Fields}}
	{{.Name}} {{.GoType}}
{{- end}}
}

{{end}}

{{define "typedef"}}
{{- if .DocURL}}// {{.TypeName}}: {{.DocURL}}
{{end -}}
{{- if .FreeFunc}}// Release with {{.FreeFunc}}.
{{end -}}
{{- if .InvalidValues}}// Invalid values: {{join .InvalidValues ", "}}.
{{end -}}
type {{.TypeName}} {{.Backing}}

{{end}}

{{define "constant"}}{{if .IsVar}}var {{.Name}} {{.GoType}} = {{.Literal}}
{{else}}const {{.Name}} {{.GoType}} = {{.Literal}}
{{end}}{{end}}

{{define "delegate"}}
{{- if .DocURL}}// {{.TypeName}}: {{.DocURL}}
{{end -}}
// {{.TypeName}} is a callback pointer: create one with NewCallback (package
// syscall) using the shape {{.Signature}}.
type {{.TypeName}} uintptr

{{end}}
